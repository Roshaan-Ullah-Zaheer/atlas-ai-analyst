# ── Database (Neon · PostgreSQL + pgvector) ─────────────────────────────
# Neon dashboard → your project → Connection string (use the pooled URL).
# Must include sslmode=require.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ── LLM (provider-agnostic: Gemini → Groq fallback) ─────────────────────
# Comma-separated Gemini keys (rotated for resilience on free tiers).
GOOGLE_API_KEYS=key1,key2
# Groq key (final text fallback when all Gemini keys are exhausted).
GROQ_API_KEY=gsk_...

# ── Observability (LangSmith · free tier) ───────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=atlas

# ── App ─────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS (the deployed frontend URL).
ALLOWED_ORIGINS=*
PORT=7860
